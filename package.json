{
  "name": "discord-botstrap",
  "version": "1.0.0",
  "description": "This is a full Typescript template for creating a Discord bot. The codebase uses the common and best practices for linting, formatting and design patterns.",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:watch": "tsc -w",
    "typecheck": "tsc --noEmit",
    "deploy:commands": "tsx src/scripts/deploy-commands.ts",
    "deploy:commands:global": "tsx src/scripts/deploy-commands.ts --global",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "keywords": ["discord", "discord.js", "bot", "typescript", "template"],
  "author": "Stefano Leone",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.34.3",
  "dependencies": {
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "pino": "^10.3.1",
    "tslib": "^2.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.21",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.6.0",
    "globals": "^17.6.0",
    "pino-pretty": "^13.1.3",
    "prettier": "3.8.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.0.18"
  }
}
